private static void runStoredMessagesSubMenu() {
// Populating required parallel standard arrays tracking targets directly from the dynamic runtime state
String[] sentMessagesArray = getFilteredArrayByStatus("Sent");
String[] disregardedMessagesArray = getFilteredArrayByStatus("Disregarded");
String[] storedMessagesArray = getFilteredArrayByStatus("Stored");

String[] messageHashArray = new String[masterMessageList.size()];
String[] messageIdArray = new String[masterMessageList.size()];

for (int index = 0; index < masterMessageList.size(); index++) {
messageHashArray[index] = masterMessageList.get(index).messageHash;
messageIdArray[index] = masterMessageList.get(index).messageID;
}

System.out.println("\n--- Part 3: Stored Messages Menu Features ---");
System.out.println("a) Display details (Sender & Recipient) of all stored messages");
System.out.println("b) Display the longest stored message description");
System.out.println("c) Search for a message by unique Message ID");
System.out.println("d) Search all messages for a particular Recipient");
System.out.println("e) Delete a message using its unique Message Hash");
System.out.println("f) Display absolute report summary of all tracked records");
System.out.print("Selection (a-f): ");
String subChoice = scanner.nextLine().trim().toLowerCase();

switch (subChoice) {
case "a":
System.out.println("\n=== Sender & Recipient Reference Matrix ===");
boolean trackingStoredFound = false;
for (Message msg : masterMessageList) {
if (msg.status.equals("Stored")) {
System.out.println("Sender Account: " + registeredUser + " ---> Recipient Target: " + msg.recipient);
trackingStoredFound = true;
}
}
if (!trackingStoredFound) {
System.out.println("No matching context records currently found marked as 'Stored'.");
}
break;

case "b":
System.out.println("\n=== Longest Stored Message Evaluation ===");
String maxDescriptionLengthText = "";
for (String textElement : storedMessagesArray) {
if (textElement.length() > maxDescriptionLengthText.length()) {
maxDescriptionLengthText = textElement;
}
}
if (!maxDescriptionLengthText.isEmpty()) {
System.out.println("Longest Recorded String: \"" + maxDescriptionLengthText + "\"");
} else {
System.out.println("No data entry elements exist within the stored messages tracking buffer.");
}
break;

case "c":
System.out.print("\nEnter target 10-digit Message ID to lookup: ");
String queryId = scanner.nextLine().trim();
boolean matchingIdDiscovered = false;

for (int idx = 0; idx < messageIdArray.length; idx++) {
if (messageIdArray[idx].equals(queryId)) {
Message target = masterMessageList.get(idx);
System.out.printf("Match Discovered! [To]: %s | [Payload]: \"%s\" (%s)%n",
target.recipient, target.content, target.status);
matchingIdDiscovered = true;
break;
}
}
if (!matchingIdDiscovered) {
System.out.println("No structural tracking record matches that specific ID context index.");
}
break;

case "d":
System.out.print("\nEnter recipient target phone number criteria: ");
String queryRecipient = scanner.nextLine().trim();
boolean matchRecipFound = false;

System.out.println("\n--- Historical Communication Matches ---");
for (Message msg : masterMessageList) {
if (msg.recipient.equals(queryRecipient)) {
System.out.printf("- status: [%s] | Text: \"%s\" (Hash: %s)%n",
msg.status, msg.content, msg.messageHash);
matchRecipFound = true;
}
}
if (!matchRecipFound) {
System.out.println("No interaction history traces exist corresponding to that recipient target.");
}
break;

case "e":
System.out.print("\nEnter absolute complete Message Hash code to perform deletion sequence: ");
String queryHash = scanner.nextLine().trim().toUpperCase();
int extractionIndex = -1;

for (int idx = 0; idx < messageHashArray.length; idx++) {
if (messageHashArray[idx].equals(queryHash)) {
extractionIndex = idx;
break;
}
}
